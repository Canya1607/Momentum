{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./src/*"],
      "momentum-haptics": ["./modules/momentum-haptics/src/index"]
    }
  },
  "include": [
